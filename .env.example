# Base de datos
WORDPRESS_DB_HOST=mysql_global
WORDPRESS_DB_NAME=wordpress_db
WORDPRESS_DB_USER=wordpress_user
WORDPRESS_DB_PASSWORD=your_password_here

# URLs del sitio (ajusta según entorno)
WP_HOME=http://tu-dominio-o-ip:8081
WP_SITEURL=http://tu-dominio-o-ip:8081

# Puerto del contenedor (default 8081)
WP_PORT=8081
