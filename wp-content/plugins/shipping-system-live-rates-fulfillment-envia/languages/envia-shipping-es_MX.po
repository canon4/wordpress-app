msgid "Envia Shipping and Fulfillment"
msgstr "Envío y Fulfillment con Envia"

msgid "The Best Shipping Solution for your business. Connect to 150+ couriers worldwide and get over 70% discounts for domestic and international shipments!"
msgstr "La mejor solución de envíos para tu negocio. Conecta con más de 150 paqueterías en todo el mundo y obtén descuentos de más del 70% en envíos nacionales e internacionales."

msgid "Envia Settings"
msgstr "Configuración de Envia"

msgid "Orders Manager"
msgstr "Gestor de pedidos"

msgid "Pickup"
msgstr "Recolección en sucursal"

msgid "Live shipping rates"
msgstr "Cotización de envíos en tiempo real"

msgid "Envia rates and shipping"
msgstr "Tarifas y envíos con Envia"

msgid "Send easily WooCommerce orders with Envia and Rate Shipment Cost."
msgstr "Envía fácilmente tus pedidos de WooCommerce con Envia y cotiza el costo de envío."

msgid "API Key"
msgstr "Clave de API"

msgid "Envia live shipping rate"
msgstr "Cotización de envío en tiempo real"

msgid "Display the shipping quote in your cart and checkout."
msgstr "Muestra la cotización de envío en tu carrito y checkout."

msgid "Carrier brand image"
msgstr "Imagen de marca de la paquetería"

msgid "Display the rate options with carrier brand image."
msgstr "Muestra las opciones de tarifa con la imagen de marca de la paquetería."

msgid "Delivery time"
msgstr "Tiempo de entrega"

msgid "Display the rate options with estimated delivery time."
