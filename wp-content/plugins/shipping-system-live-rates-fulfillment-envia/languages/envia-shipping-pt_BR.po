msgstr "Configurações da Envia"

msgid "Orders Manager"
msgstr "Gerenciador de pedidos"

msgid "Pickup"
msgstr "Retirada em ponto"

msgid "Live shipping rates"
msgstr "Tarifas de envio em tempo real"

msgid "Envia rates and shipping"
msgstr "Tarifas e envios com Envia"

msgid "Send easily WooCommerce orders with Envia and Rate Shipment Cost."
msgstr "Envie facilmente seus pedidos do WooCommerce com Envia e calcule o custo de envio."

msgid "API Key"
msgstr "Chave de API"

msgid "Envia live shipping rate"
msgstr "Tarifa de envio em tempo real"

msgid "Display the shipping quote in your cart and checkout."
msgstr "Exibe a cotação de envio no seu carrinho e checkout."

msgid "Carrier brand image"
msgstr "Imagem da transportadora"

